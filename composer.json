{
    "name": "tangwei/database-doris",
    "description": "The doris driver for hyperf/database.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "php",
        "swoole",
        "hyperf",
        "database",
        "doris"
    ],
    "homepage": "https://hyperf.io",
    "support": {
        "issues": "https://github.com/hyperf/hyperf/issues",
        "source": "https://github.com/hyperf/hyperf",
        "docs": "https://hyperf.wiki",
        "pull-request": "https://github.com/hyperf/hyperf/pulls"
    },
    "require": {
        "php": ">=8.1",
        "hyperf/database": "~3.1.0"
    },
    "autoload": {
        "psr-4": {
            "Hyperf\\Database\\Doris\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HyperfTest\\Database\\Doris\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-master": "3.1-dev"
        },
        "hyperf": {
            "config": "Hyperf\\Database\\Doris\\ConfigProvider"
        }
    }
}
